@page "/admin"
@using ArtSite.Shared.DTOs
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IAuthService AuthService
@inject IApiService ApiService
@inject NavigationManager Navigation

<h1>Admin Panel</h1>
<div style="display: flex; gap: 10px; margin-bottom: 20px;">
  <button @onclick="HandleLogout">Logout</button>
  <button @onclick="OpenLocationsModal" style="background: #0d6efd; color: white; border: none; padding: 8px 16px; cursor: pointer;">Manage Locations</button>
  <button @onclick="OpenShowsModal" style="background: #198754; color: white; border: none; padding: 8px 16px; cursor: pointer;">Manage Shows</button>
</div>

<LocationsModal IsOpen="@isLocationsModalOpen" OnClose="@CloseLocationsModal" />
<ShowsModal IsOpen="@isShowsModalOpen" OnClose="@CloseShowsModal" />

<hr />

<h2>Add New Artwork</h2>
<div style="border: 1px solid #ccc; padding: 20px; margin-bottom: 20px;">
  <EditForm Model="@newArtwork" OnValidSubmit="@HandleCreateArtwork">
    <div>
      <label>Title:</label>
      <InputText @bind-Value="newArtwork.Title" style="width: 100%; margin-bottom: 10px;" />
    </div>
    <div>
      <label>Medium:</label>
      <InputText @bind-Value="newArtwork.Medium" style="width: 100%; margin-bottom: 10px;" />
    </div>
    <div>
      <label>Category:</label>
      <InputText @bind-Value="newArtwork.Category" style="width: 100%; margin-bottom: 10px;" />
    </div>
    <div>
      <label>Dimensions:</label>
      <InputText @bind-Value="newArtwork.Dimensions" style="width: 100%; margin-bottom: 10px;" />
    </div>
    <div>
      <label>Year:</label>
      <InputNumber @bind-Value="newArtwork.Year" style="width: 100%; margin-bottom: 10px;" />
    </div>
    <div>
      <label>Price:</label>
      <InputNumber @bind-Value="newArtwork.Price" style="width: 100%; margin-bottom: 10px;" />
    </div>
    <div>
      <label>Available:</label>
      <InputCheckbox @bind-Value="newArtwork.Available" style="margin-bottom: 10px;" />
    </div>
    <div>
      <label>Location (optional):</label>
      <InputSelect @bind-Value="newArtwork.LocationId" style="width: 100%; margin-bottom: 10px;">
        <option value="">Select location...</option>
        @if (allLocations != null)
        {
          @foreach (var location in allLocations)
          {
            <option value="@location.LocationId">@location.Name - @location.City, @location.State</option>
          }
        }
      </InputSelect>
    </div>

    @if (!string.IsNullOrEmpty(createMessage))
    {
      <div style="color: @(createSuccess ? "green" : "red"); margin: 10px 0;">
        @createMessage
      </div>
    }

    <button type="submit" disabled="@isCreating">
      @(isCreating ? "Creating..." : "Create Artwork")
    </button>
  </EditForm>

  @if (newlyCreatedArtworkId.HasValue)
  {
    <div style="margin-top: 20px; padding: 10px; background-color: #f0f0f0;">
      <h3>Upload Image for "@newArtwork.Title"</h3>
      <InputFile OnChange="@HandleImageSelected" />

      @if (!string.IsNullOrEmpty(uploadMessage))
      {
        <div style="color: @(uploadSuccess ? "green" : "red"); margin: 10px 0;">
          @uploadMessage
        </div>
      }

      @if (selectedFile != null)
      {
        <button @onclick="HandleUploadImage" disabled="@isUploading">
          @(isUploading ? "Uploading..." : "Upload Image")
        </button>
      }
    </div>
  }
</div>

<hr />

<h2>Artworks</h2>
@if (artworks == null)
{
  <p>Loading...</p>
}
else if (artworks.Count == 0)
{
  <p>No artworks yet. Create one above!</p>
}
else
{
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
    @foreach (var artwork in artworks)
    {
      <div style="border: 1px solid #ccc; padding: 15px; background: #f9f9f9; display: flex; flex-direction: column;">
        @if (editingArtworkId == artwork.ArtWorkId)
        {
          <!-- Edit Form -->
          <h3>Edit Artwork (ID: @artwork.ArtWorkId)</h3>
        <EditForm Model="@editingArtwork" OnValidSubmit="@HandleUpdateArtwork">
          <div>
            <label>Title:</label>
            <InputText @bind-Value="editingArtwork.Title" style="width: 100%; margin-bottom: 10px;" />
          </div>
          <div>
            <label>Medium:</label>
            <InputText @bind-Value="editingArtwork.Medium" style="width: 100%; margin-bottom: 10px;" />
          </div>
          <div>
            <label>Category:</label>
            <InputText @bind-Value="editingArtwork.Category" style="width: 100%; margin-bottom: 10px;" />
          </div>
          <div>
            <label>Dimensions:</label>
            <InputText @bind-Value="editingArtwork.Dimensions" style="width: 100%; margin-bottom: 10px;" />
          </div>
          <div>
            <label>Year:</label>
            <InputNumber @bind-Value="editingArtwork.Year" style="width: 100%; margin-bottom: 10px;" />
          </div>
          <div>
            <label>Price:</label>
            <InputNumber @bind-Value="editingArtwork.Price" style="width: 100%; margin-bottom: 10px;" />
          </div>
          <div>
            <label>Available:</label>
            <InputCheckbox @bind-Value="editingArtwork.Available" style="margin-bottom: 10px;" />
          </div>
          <div>
            <label>Location (optional):</label>
            <InputSelect @bind-Value="editingArtwork.LocationId" style="width: 100%; margin-bottom: 10px;">
              <option value="">Select location...</option>
              @if (allLocations != null)
              {
                @foreach (var location in allLocations)
                {
                  <option value="@location.LocationId">@location.Name - @location.City, @location.State</option>
                }
              }
            </InputSelect>
          </div>

          @if (!string.IsNullOrEmpty(editMessage))
          {
            <div style="color: @(editSuccess ? "green" : "red"); margin: 10px 0;">
              @editMessage
            </div>
          }

          <button type="submit" disabled="@isEditing">
            @(isEditing ? "Saving..." : "Save Changes")
          </button>
          <button type="button" @onclick="CancelEdit" style="margin-left: 10px;">Cancel</button>
        </EditForm>
      }
      else
      {
        <!-- Display View -->
        <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 10px;">
          <h3 style="margin: 0; font-size: 1.2rem;">@artwork.Title</h3>
          <div style="display: flex; gap: 5px;">
            <button @onclick="@(() => StartEdit(artwork.ArtWorkId))" style="padding: 5px 10px; cursor: pointer;">Edit</button>
            <button @onclick="@(() => StartDelete(artwork.ArtWorkId))" style="padding: 5px 10px; background: #dc3545; color: white; border: none; cursor: pointer;">Delete</button>
          </div>
        </div>

        @if (!string.IsNullOrEmpty(artwork.PrimaryImageUrl))
        {
          <div style="margin: 10px 0; flex-grow: 1; display: flex; align-items: center; justify-content: center; overflow: hidden; max-height: 250px;">
            <img src="@artwork.PrimaryImageUrl" alt="@artwork.Title" style="width: 100%; height: 100%; object-fit: cover;" />
          </div>
        }
        else
        {
          <div style="flex-grow: 1; display: flex; align-items: center; justify-content: center; min-height: 150px; background: #e9ecef;">
            <p style="color: #999;">No image uploaded</p>
          </div>
        }

        <div style="margin-top: 10px;">
          <p style="margin: 5px 0;"><strong>Medium:</strong> @artwork.Medium</p>
          <p style="margin: 5px 0;"><strong>Year:</strong> @artwork.Year</p>
          @if (artwork.Price.HasValue)
          {
            <p style="margin: 5px 0;"><strong>Price:</strong> $@artwork.Price.Value</p>
          }
          <p style="margin: 5px 0;"><strong>Available:</strong> @(artwork.Available ? "Yes" : "No")</p>
        </div>
      }

      <div style="margin-top: 10px; padding: 10px; background: white; border: 1px solid #ddd;">
        <h4>Upload/Change Image</h4>
        <InputFile OnChange="@((e) => HandleImageSelectedForArtwork(e, artwork.ArtWorkId))" />

        @if (uploadingArtworkId == artwork.ArtWorkId && selectedFileForArtwork != null)
        {
          <button @onclick="@(() => HandleUploadImageForExisting(artwork.ArtWorkId))"
                  disabled="@isUploadingExisting"
                  style="margin-top: 5px;">
            @(isUploadingExisting ? "Uploading..." : "Upload Image")
          </button>
        }

        @if (uploadMessageForArtwork.ContainsKey(artwork.ArtWorkId))
        {
          <div style="color: @(uploadSuccessForArtwork.GetValueOrDefault(artwork.ArtWorkId) ? "green" : "red"); margin-top: 5px;">
            @uploadMessageForArtwork[artwork.ArtWorkId]
          </div>
        }
      </div>
      </div>
    }
  </div>
}

@if (deletingArtworkId.HasValue)
{
  <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center; z-index: 1000;">
    <div style="background: white; padding: 20px; border-radius: 8px; max-width: 400px; width: 90%;">
      <h3>Confirm Delete</h3>
      <p>Are you sure you want to delete this artwork? This action cannot be undone.</p>
      <div style="display: flex; gap: 10px; margin-top: 20px;">
        <button @onclick="ConfirmDelete" disabled="@isDeleting" style="padding: 10px 20px; background: #dc3545; color: white; border: none; cursor: pointer;">
          @(isDeleting ? "Deleting..." : "Yes, Delete")
        </button>
        <button @onclick="CancelDelete" disabled="@isDeleting" style="padding: 10px 20px; background: #6c757d; color: white; border: none; cursor: pointer;">
          Cancel
        </button>
      </div>
    </div>
  </div>
}

@code {
  private List<ArtworkDto>? artworks;
  private List<LocationDto>? allLocations;
  private CreateArtworkDto newArtwork = new();
  private bool isCreating = false;
  private bool isUploading = false;
  private string? createMessage;
  private bool createSuccess = false;
  private string? uploadMessage;
  private bool uploadSuccess = false;
  private int? newlyCreatedArtworkId;
  private IBrowserFile? selectedFile;

  // For existing artwork uploads
  private IBrowserFile? selectedFileForArtwork;
  private int? uploadingArtworkId;
  private bool isUploadingExisting = false;
  private Dictionary<int, string> uploadMessageForArtwork = new();
  private Dictionary<int, bool> uploadSuccessForArtwork = new();

  // For editing
  private int? editingArtworkId;
  private UpdateArtworkDto editingArtwork = new();
  private bool isEditing = false;
  private string? editMessage;
  private bool editSuccess = false;

  // For deleting
  private int? deletingArtworkId;
  private bool isDeleting = false;

  // For locations modal
  private bool isLocationsModalOpen = false;

  // For shows modal
  private bool isShowsModalOpen = false;

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      var isAuthenticated = await AuthService.IsAuthenticatedAsync();

      if (!isAuthenticated)
      {
        Navigation.NavigateTo("/login", true);
      }
      else
      {
        await LoadArtworks();
        await LoadLocations();
        StateHasChanged();
      }
    }
  }

  private async Task LoadArtworks()
  {
    try
    {
      artworks = await Http.GetFromJsonAsync<List<ArtworkDto>>("api/artwork");
    }
    catch (Exception ex)
    {
      Console.WriteLine($"Error loading artworks: {ex.Message}");
      artworks = new List<ArtworkDto>();
    }
  }

  private async Task LoadLocations()
  {
    try
    {
      allLocations = await Http.GetFromJsonAsync<List<LocationDto>>("api/location");
    }
    catch (Exception ex)
    {
      Console.WriteLine($"Error loading locations: {ex.Message}");
      allLocations = new List<LocationDto>();
    }
  }

  private async Task HandleCreateArtwork()
  {
    isCreating = true;
    createMessage = null;

    try
    {
      var httpClient = await ApiService.GetAuthenticatedHttpClientAsync();
      var response = await httpClient.PostAsJsonAsync("api/artwork", newArtwork);

      if (response.IsSuccessStatusCode)
      {
        var createdArtwork = await response.Content.ReadFromJsonAsync<ArtworkDetailDto>();
        newlyCreatedArtworkId = createdArtwork?.ArtWorkId;
        createMessage = "Artwork created! Now upload an image.";
        createSuccess = true;
        await LoadArtworks();
      }
      else
      {
        createMessage = $"Failed to create artwork: {response.StatusCode}";
        createSuccess = false;
      }
    }
    catch (Exception ex)
    {
      createMessage = $"Error: {ex.Message}";
      createSuccess = false;
    }

    isCreating = false;
  }

  private void HandleImageSelected(InputFileChangeEventArgs e)
  {
    selectedFile = e.File;
    uploadMessage = null;
  }

  private async Task HandleUploadImage()
  {
    if (selectedFile == null || !newlyCreatedArtworkId.HasValue) return;

    isUploading = true;
    uploadMessage = null;

    try
    {
      var httpClient = await ApiService.GetAuthenticatedHttpClientAsync();

      using var content = new MultipartFormDataContent();
      var fileContent = new StreamContent(selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024)); // 10MB max
      fileContent.Headers.ContentType = new MediaTypeHeaderValue(selectedFile.ContentType);
      content.Add(fileContent, "image", selectedFile.Name);
      content.Add(new StringContent("true"), "isPrimary");

      var response = await httpClient.PostAsync($"api/artwork/{newlyCreatedArtworkId}/images", content);

      if (response.IsSuccessStatusCode)
      {
        uploadMessage = "Image uploaded successfully!";
        uploadSuccess = true;

        // Reset form
        newArtwork = new CreateArtworkDto();
        newlyCreatedArtworkId = null;
        selectedFile = null;

        await LoadArtworks();
      }
      else
      {
        var error = await response.Content.ReadAsStringAsync();
        uploadMessage = $"Failed to upload image: {error}";
        uploadSuccess = false;
      }
    }
    catch (Exception ex)
    {
      uploadMessage = $"Error: {ex.Message}";
      uploadSuccess = false;
    }

    isUploading = false;
  }

  private void HandleImageSelectedForArtwork(InputFileChangeEventArgs e, int artworkId)
  {
    selectedFileForArtwork = e.File;
    uploadingArtworkId = artworkId;
    uploadMessageForArtwork.Remove(artworkId);
  }

  private async Task HandleUploadImageForExisting(int artworkId)
  {
    if (selectedFileForArtwork == null) return;

    isUploadingExisting = true;
    uploadMessageForArtwork.Remove(artworkId);

    try
    {
      var httpClient = await ApiService.GetAuthenticatedHttpClientAsync();

      using var content = new MultipartFormDataContent();
      var fileContent = new StreamContent(selectedFileForArtwork.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
      fileContent.Headers.ContentType = new MediaTypeHeaderValue(selectedFileForArtwork.ContentType);
      content.Add(fileContent, "image", selectedFileForArtwork.Name);
      content.Add(new StringContent("true"), "isPrimary");

      var response = await httpClient.PostAsync($"api/artwork/{artworkId}/images", content);

      if (response.IsSuccessStatusCode)
      {
        uploadMessageForArtwork[artworkId] = "Image uploaded successfully!";
        uploadSuccessForArtwork[artworkId] = true;

        selectedFileForArtwork = null;
        uploadingArtworkId = null;

        await LoadArtworks();
      }
      else
      {
        var error = await response.Content.ReadAsStringAsync();
        uploadMessageForArtwork[artworkId] = $"Failed: {error}";
        uploadSuccessForArtwork[artworkId] = false;
      }
    }
    catch (Exception ex)
    {
      uploadMessageForArtwork[artworkId] = $"Error: {ex.Message}";
      uploadSuccessForArtwork[artworkId] = false;
    }

    isUploadingExisting = false;
  }

  private async Task StartEdit(int artworkId)
  {
    try
    {
      var httpClient = await ApiService.GetAuthenticatedHttpClientAsync();
      var artworkDetail = await httpClient.GetFromJsonAsync<ArtworkDetailDto>($"api/artwork/{artworkId}");

      if (artworkDetail != null)
      {
        editingArtworkId = artworkId;
        editingArtwork = new UpdateArtworkDto
        {
          Title = artworkDetail.Title,
          Medium = artworkDetail.Medium,
          Category = artworkDetail.Category,
          Dimensions = artworkDetail.Dimensions,
          Year = artworkDetail.Year,
          Price = artworkDetail.Price,
          Available = artworkDetail.Available,
          LocationId = artworkDetail.Location?.LocationId
        };
        editMessage = null;
      }
    }
    catch (Exception ex)
    {
      Console.WriteLine($"Error loading artwork for edit: {ex.Message}");
    }
  }

  private void CancelEdit()
  {
    editingArtworkId = null;
    editingArtwork = new UpdateArtworkDto();
    editMessage = null;
  }

  private async Task HandleUpdateArtwork()
  {
    if (!editingArtworkId.HasValue) return;

    isEditing = true;
    editMessage = null;

    try
    {
      var httpClient = await ApiService.GetAuthenticatedHttpClientAsync();
      var response = await httpClient.PutAsJsonAsync($"api/artwork/{editingArtworkId}", editingArtwork);

      if (response.IsSuccessStatusCode)
      {
        editMessage = "Artwork updated successfully!";
        editSuccess = true;

        await LoadArtworks();

        // Close edit form after short delay
        await Task.Delay(1000);
        CancelEdit();
      }
      else
      {
        var errorContent = await response.Content.ReadAsStringAsync();
        Console.WriteLine($"Update failed: {response.StatusCode} - {errorContent}");
        editMessage = $"Failed to update: {response.StatusCode} - {errorContent}";
        editSuccess = false;
      }
    }
    catch (Exception ex)
    {
      Console.WriteLine($"Update exception: {ex.Message}");
      editMessage = $"Error: {ex.Message}";
      editSuccess = false;
    }

    isEditing = false;
  }

  private void StartDelete(int artworkId)
  {
    deletingArtworkId = artworkId;
  }

  private void CancelDelete()
  {
    deletingArtworkId = null;
  }

  private async Task ConfirmDelete()
  {
    if (!deletingArtworkId.HasValue) return;

    isDeleting = true;

    try
    {
      var httpClient = await ApiService.GetAuthenticatedHttpClientAsync();
      var response = await httpClient.DeleteAsync($"api/artwork/{deletingArtworkId}");

      if (response.IsSuccessStatusCode)
      {
        await LoadArtworks();
        deletingArtworkId = null;
      }
      else
      {
        var error = await response.Content.ReadAsStringAsync();
        Console.WriteLine($"Delete failed: {response.StatusCode} - {error}");
      }
    }
    catch (Exception ex)
    {
      Console.WriteLine($"Delete exception: {ex.Message}");
    }

    isDeleting = false;
  }

  private void OpenLocationsModal()
  {
    isLocationsModalOpen = true;
  }

  private void CloseLocationsModal()
  {
    isLocationsModalOpen = false;
  }

  private void OpenShowsModal()
  {
    isShowsModalOpen = true;
  }

  private void CloseShowsModal()
  {
    isShowsModalOpen = false;
  }

  private async Task HandleLogout()
  {
    await AuthService.LogoutAsync();
    Navigation.NavigateTo("/login");
  }
}